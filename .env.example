# Sofascore API rate-limiting configuration
# Copy this file to .env and adjust values as needed.
# All delay defaults are 0 (no throttling).  Set these to positive values
# if Sofascore starts returning 403/429 responses.

# Seconds between consecutive Sofascore API calls (base delay)
# SOFASCORE_INTER_REQUEST_DELAY=0

# HTTP request timeout in seconds
# SOFASCORE_REQUEST_TIMEOUT=10

# Maximum number of retry attempts for retryable errors
# SOFASCORE_MAX_RETRIES=3

# Base delay for exponential backoff on retries (seconds)
# SOFASCORE_RETRY_BASE_DELAY=0

# Multiplier applied to inter-request delay on 403/429 responses
# SOFASCORE_ADAPTIVE_DELAY_MULTIPLIER=2.0

# Maximum adaptive delay ceiling (seconds)
# SOFASCORE_ADAPTIVE_DELAY_MAX=0

# Delay between league API calls in the shortlist generator (seconds)
# SOFASCORE_INTER_LEAGUE_DELAY=0

# Delay between API calls in the training pipeline (seconds)
# SOFASCORE_API_CALL_DELAY=0

# Cache directory (defaults to data/cache/)
# CACHE_DIR=data/cache/
